{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Cloak",
  "version": "0.1.0",
  "identifier": "app.cloak.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "Cloak",
        "width": 1200,
        "height": 800,
        "minWidth": 940,
        "minHeight": 640,
        "center": true,
        "resizable": true,
        "fullscreen": false,
        "maximized": false,
        "decorations": true,
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "M. Yousuf",
    "copyright": "Copyright © 2026 M. Yousuf — https://yousuf-dev.com",
    "icon": [
      "icons/32x32.png",
      "icons/64x64.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
