# --- Core ---
NODE_ENV=development
PORT=4000
MONGODB_URI=mongodb://127.0.0.1:27017/cloak

# --- Auth / tokens (generate strong random values, min 32 chars) ---
JWT_SECRET=change-me-to-a-long-random-string-min-32-chars
REFRESH_SECRET=change-me-to-another-long-random-string-32
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=30d
OTP_TTL_SECONDS=600

# --- Rate limiting ---
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_AUTH_MAX=5
RATE_LIMIT_API_MAX=100
RATE_LIMIT_UPLOAD_MAX=20

# --- CORS / logging ---
CORS_ORIGIN=*
LOG_LEVEL=info

# --- Optional integrations (absence disables the feature; app still boots) ---
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=no-reply@yourdomain.com
# CLOUDINARY_URL=cloudinary://<key>:<secret>@<cloud_name>
