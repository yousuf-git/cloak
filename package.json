{
  "name": "cloak",
  "version": "0.0.0",
  "private": true,
  "description": "Zero-knowledge, developer-centric secrets manager and password vault (desktop).",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev:api": "pnpm --filter @cloak/api dev",
    "dev:desktop": "pnpm --filter @cloak/desktop dev",
    "dev:web": "pnpm --filter @cloak/web dev",
    "build:api": "pnpm --filter @cloak/api build",
    "build:desktop": "pnpm --filter @cloak/desktop build",
    "build:web": "pnpm --filter @cloak/web build",
    "ship": "bash scripts/ship.sh",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "argon2",
      "esbuild",
      "sharp",
      "unrs-resolver"
    ]
  }
}
